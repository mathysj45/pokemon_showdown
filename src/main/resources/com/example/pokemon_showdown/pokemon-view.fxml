<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.FlowPane?>

<?import javafx.geometry.Insets?>
<FlowPane fx:id="contain"
          xmlns="http://javafx.com/javafx"
          xmlns:fx="http://javafx.com/fxml"
          fx:controller="com.example.pokemon_showdown.Controller.view.ActionTeamView">

    <VBox fx:id="containStats" alignment="CENTER" spacing="40.0">
        <HBox alignment="CENTER" spacing="40.0">

            <VBox alignment="CENTER" spacing="20.0">
                <Text fx:id="pokemonName" text="Espèce"/>
                <ImageView fx:id="pokemonSprite" fitWidth="70.0"
                           fitHeight="70.0" preserveRatio="true"/>
            </VBox>

            <GridPane alignment="CENTER" hgap="15.0" vgap="10.0">
                <Text text="Niveau:" styleClass="informationArea"
                      GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Text fx:id="levelData" text="100" styleClass="dataArea"
                      GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Text text="Type:" styleClass="informationArea"
                      GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <Text fx:id="pokemonType1Data" styleClass="dataArea"
                      GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Text fx:id="pokemonType2Data" styleClass="dataArea"
                      GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            </GridPane>

            <VBox alignment="CENTER" spacing="5.0">
                <Text fx:id="pokemonMoveInfo" text="Capacités:"
                      styleClass="informationArea">
                    <VBox.margin>
                        <Insets bottom="10.0"/>
                    </VBox.margin>
                </Text>
                <Text fx:id="pokemonMove1Data" styleClass="dataArea"/>
                <Text fx:id="pokemonMove2Data" styleClass="dataArea"/>
                <Text fx:id="pokemonMove3Data" styleClass="dataArea"/>
                <Text fx:id="pokemonMove4Data" styleClass="dataArea"/>
            </VBox>

            <GridPane alignment="CENTER" hgap="10.0" vgap="5.0">
                <Text text="Stats" styleClass="informationArea"
                      GridPane.columnIndex="0" GridPane.rowIndex="0"
                      GridPane.columnSpan="2" GridPane.halignment="CENTER"/>

                <Text text="PV" styleClass="informationArea"
                      GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <Text fx:id="pokemonHpData" styleClass="dataArea"
                      GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Text text="Atk" styleClass="informationArea"
                      GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <Text fx:id="pokemonAttackData" styleClass="dataArea"
                      GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Text text="Def" styleClass="informationArea"
                      GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <Text fx:id="pokemonDefenseData" styleClass="dataArea"
                      GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Text text="SpA" styleClass="informationArea"
                      GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <Text fx:id="pokemonSpeAttackData" styleClass="dataArea"
                      GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                <Text text="SpD" styleClass="informationArea"
                      GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                <Text fx:id="pokemonSpeDefenseData" styleClass="dataArea"
                      GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                <Text text="Vit" styleClass="informationArea"
                      GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                <Text fx:id="pokemonSpeedData" styleClass="dataArea"
                      GridPane.columnIndex="1" GridPane.rowIndex="6"/>
            </GridPane>
        </HBox>
        <ComboBox fx:id="itemComboBox" styleClass="selectArea"
                  prefWidth="150.0"
                  promptText="Item...">
        </ComboBox>
    </VBox>

    <VBox fx:id="pokemonListTop"  alignment="CENTER" spacing="5.0">
        <children>
            <Label fx:id="pokemonSelect"
                   text="Sélectionnez vos monstres (3 minimum)"
                   styleClass="informationArea"/>
            <HBox fx:id="pokemonList" spacing="10" alignment="CENTER">
                <ComboBox fx:id="teamBuilder" styleClass="selectArea"
                          prefWidth="200.0" promptText="Choisir..." />
                <Button text="Ajouter" onAction="#addPokemonToTeam" />
            </HBox>
            <ListView fx:id="teamListView" prefHeight="200.0" />
            <HBox spacing="15" alignment="CENTER">
                <Button text="Retirer"
                        onAction="#removePokemonFromTeam"
                        styleClass="deleteButton" />
                <Button fx:id="fightButton" text="Démarrer le combat"
                        disable="true" />
            </HBox>
        </children>
    </VBox>
</FlowPane>