<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="30.0" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.pokemon_showdown.Controller.view.TeamBuilderController">

    <HBox alignment="CENTER" spacing="40.0">

        <VBox alignment="CENTER" spacing="10.0">
            <Text fx:id="pokemonName" text="Name"/>
            <ImageView fx:id="pokemonSprite"/>
        </VBox>

        <GridPane alignment="CENTER" hgap="15.0" vgap="10.0">
            <Text text="Level:" styleClass="informationArea"
                  GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Text fx:id="levelData" text="100" styleClass="dataArea"
                  GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Text text="Type:" styleClass="informationArea"
                  GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <Text fx:id="pokemonType1Data" styleClass="dataArea"
                  GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            <Text fx:id="pokemonType2Data" styleClass="dataArea"
                  GridPane.columnIndex="2" GridPane.rowIndex="1"/>

            <Text text="Item:" styleClass="informationArea"
                  GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <Text fx:id="pokemonItemData" styleClass="dataArea"
                  GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        </GridPane>

        <VBox alignment="CENTER" spacing="5.0">
            <Text text="Moves:" styleClass="informationArea"/>
            <Text fx:id="pokemonMove1Data" styleClass="dataArea"/>
            <Text fx:id="pokemonMove2Data" styleClass="dataArea"/>
            <Text fx:id="pokemonMove3Data" styleClass="dataArea"/>
            <Text fx:id="pokemonMove4Data" styleClass="dataArea"/>
        </VBox>

        <GridPane alignment="CENTER" hgap="10.0" vgap="5.0">
            <Text text="Stats" styleClass="informationArea"
                  GridPane.columnIndex="0" GridPane.rowIndex="0"
                  GridPane.columnSpan="2" GridPane.halignment="CENTER"/>

            <Text text="HP" styleClass="informationArea"
                  GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <Text fx:id="pokemonHpData" styleClass="dataArea"
                  GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Text text="Atk" styleClass="informationArea"
                  GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <Text fx:id="pokemonAttackData" styleClass="dataArea"
                  GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Text text="Def" styleClass="informationArea"
                  GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <Text fx:id="pokemonDefenseData" styleClass="dataArea"
                  GridPane.columnIndex="1" GridPane.rowIndex="3"/>

            <Text text="SpA" styleClass="informationArea"
                  GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <Text fx:id="pokemonSpeAttackData" styleClass="dataArea"
                  GridPane.columnIndex="1" GridPane.rowIndex="4"/>

            <Text text="SpD" styleClass="informationArea"
                  GridPane.columnIndex="0" GridPane.rowIndex="5"/>
            <Text fx:id="pokemonSpeDefenseData" styleClass="dataArea"
                  GridPane.columnIndex="1" GridPane.rowIndex="5"/>

            <Text text="Spe" styleClass="informationArea"
                  GridPane.columnIndex="0" GridPane.rowIndex="6"/>
            <Text fx:id="pokemonSpeedData" styleClass="dataArea"
                  GridPane.columnIndex="1" GridPane.rowIndex="6"/>
        </GridPane>

    </HBox>

    <ComboBox fx:id="teamBuilder" prefWidth="150.0" promptText="Add pokemon..." />

</VBox>