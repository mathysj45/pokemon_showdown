<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.control.TextArea?>

<?import javafx.scene.image.ImageView?>
<VBox fx:id="battleContain"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.pokemon_showdown.Controller.FightController">

    <GridPane fx:id="battleGrid" vgap="10.0" hgap="10.0" VBox.vgrow="ALWAYS">

        <columnConstraints>
            <ColumnConstraints percentWidth="33.3" halignment="CENTER"/>
            <ColumnConstraints percentWidth="33.3" halignment="CENTER"/>
            <ColumnConstraints percentWidth="33.4" halignment="CENTER"/>
        </columnConstraints>

        <rowConstraints>
            <RowConstraints percentHeight="50" valignment="CENTER"/>
            <RowConstraints percentHeight="25" valignment="CENTER"/>
            <RowConstraints percentHeight="25" valignment="CENTER"/>
        </rowConstraints>

        <GridPane fx:id="battleField"
                  GridPane.columnIndex="0"
                  GridPane.rowIndex="0"
                  GridPane.columnSpan="2"
                  GridPane.rowSpan="3"
                  maxHeight="Infinity"
                  maxWidth="Infinity">

            <columnConstraints>
                <ColumnConstraints percentWidth="50.0" halignment="CENTER"/>
                <ColumnConstraints percentWidth="50.0" halignment="CENTER"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints percentHeight="50.0" valignment="CENTER"/>
                <RowConstraints percentHeight="50.0" valignment="CENTER"/>
            </rowConstraints>

            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" alignment="CENTER" spacing="5.0">
                <VBox styleClass="containBattleView" prefWidth="150.0" maxWidth="-Infinity" alignment="CENTER" spacing="5.0">
                    <Text fx:id="nameP2" text="Nom Adversaire"/>
                    <ProgressBar fx:id="healthBarP2" progress="1.0" prefWidth="130.0"/>
                    <Text fx:id="hpTextP2" text="HP / HP"/>
                </VBox>
                <ImageView fx:id="spriteP2" fitHeight="200.0" fitWidth="200.0" preserveRatio="true"/>
            </VBox>

            <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" alignment="CENTER" spacing="5.0">
                <VBox styleClass="containBattleView" prefWidth="150.0" maxWidth="-Infinity" alignment="CENTER" spacing="5.0">
                    <Text fx:id="nameP1" text="Nom Joueur"/>
                    <ProgressBar fx:id="healthBarP1" progress="1.0" prefWidth="130.0"/>
                    <Text fx:id="hpTextP1" text="HP / HP"/>
                </VBox>
                <ImageView fx:id="spriteP1" fitHeight="200.0" fitWidth="200.0" preserveRatio="true"/>
            </VBox>
        </GridPane>

        <VBox styleClass="containBattleView" GridPane.columnIndex="0"
              GridPane.rowIndex="3"
              GridPane.columnSpan="2"
              maxHeight="Infinity"
              maxWidth="Infinity"
              spacing="10.0">
            <Text>CAPACITES</Text>
            <HBox spacing="10.0">
                <Button fx:id="pokemonMove1Data" onAction="#onMove1Clicked" styleClass="attackArea"/>
                <Button fx:id="pokemonMove2Data" onAction="#onMove2Clicked" styleClass="attackArea"/>
                <Button fx:id="pokemonMove3Data" onAction="#onMove3Clicked" styleClass="attackArea"/>
                <Button fx:id="pokemonMove4Data" onAction="#onMove4Clicked" styleClass="attackArea"/>
            </HBox>

            <Text>MONSTIES</Text>
            <HBox fx:id="teamListContainer" spacing="5.0" />
        </VBox>

        <VBox styleClass="containBattleView" GridPane.columnIndex="2"
              GridPane.rowIndex="0"
              GridPane.rowSpan="4"
              maxHeight="Infinity"
              maxWidth="Infinity">
            <TextArea fx:id="battleLog"
                      editable="false"
                      wrapText="true"
                      VBox.vgrow="ALWAYS"
                      maxHeight="Infinity"
                      maxWidth="Infinity"
                      style="-fx-control-inner-background: #F0F0E8; -fx-font-family: 'Consolas';"/>
        </VBox>
    </GridPane>
</VBox>