<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Text?>

<VBox fx:id="battleContain"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.pokemon_showdown.Controller.view.battle.BattleView">

    <GridPane fx:id="battleGrid" vgap="10.0" hgap="10.0" VBox.vgrow="ALWAYS">

        <columnConstraints>
            <ColumnConstraints percentWidth="33.3" halignment="CENTER"/>
            <ColumnConstraints percentWidth="33.3" halignment="CENTER"/>
            <ColumnConstraints percentWidth="33.4" halignment="CENTER"/>
        </columnConstraints>

        <rowConstraints>
            <RowConstraints percentHeight="20" valignment="CENTER"/>
            <RowConstraints percentHeight="20" valignment="CENTER"/>
            <RowConstraints percentHeight="20" valignment="CENTER"/>
            <RowConstraints percentHeight="20" valignment="CENTER"/>
            <RowConstraints percentHeight="20" valignment="CENTER"/>
        </rowConstraints>

        <Button text="Zone Étendue"
                GridPane.columnIndex="0"
                GridPane.rowIndex="0"
                GridPane.columnSpan="2"
                GridPane.rowSpan="4"
                maxHeight="Infinity"
                maxWidth="Infinity"/>

        <VBox GridPane.columnIndex="0"
              GridPane.rowIndex="4"
              maxHeight="Infinity"
              maxWidth="Infinity"
              spacing="10.0">
            <Text>CAPACITES</Text>
            <HBox>
                <Text>JE SUIS UNE LISTE DE CAPACITES</Text>
            </HBox>

            <Text>POKEMON</Text>
            <HBox>
                <Text>JE SUIS UNE LISTE DE POKEMON</Text>
            </HBox>
        </VBox>

        <VBox GridPane.columnIndex="2"
              GridPane.rowIndex="0"
              maxHeight="Infinity"
              maxWidth="Infinity">
            <Text>JE SUIS UN CHAT</Text>
        </VBox>

    </GridPane>
</VBox>