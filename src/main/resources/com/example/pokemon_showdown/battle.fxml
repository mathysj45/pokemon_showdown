<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Text?>

<VBox fx:id="battleContain"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.pokemon_showdown.Controller.FightController">

    <GridPane fx:id="battleGrid" vgap="10.0" hgap="10.0" VBox.vgrow="ALWAYS">

        <columnConstraints>
            <ColumnConstraints percentWidth="33.3" halignment="CENTER"/>
            <ColumnConstraints percentWidth="33.3" halignment="CENTER"/>
            <ColumnConstraints percentWidth="33.4" halignment="CENTER"/>
        </columnConstraints>

        <rowConstraints>
            <RowConstraints percentHeight="20" valignment="CENTER"/>
            <RowConstraints percentHeight="20" valignment="CENTER"/>
            <RowConstraints percentHeight="20" valignment="CENTER"/>
            <RowConstraints percentHeight="20" valignment="CENTER"/>
            <RowConstraints percentHeight="20" valignment="CENTER"/>
        </rowConstraints>

        <GridPane GridPane.columnIndex="0"
                  GridPane.rowIndex="0"
                  GridPane.columnSpan="2"
                  GridPane.rowSpan="4"
                  maxHeight="Infinity"
                  maxWidth="Infinity">

            <columnConstraints>
                <ColumnConstraints percentWidth="50.0" halignment="CENTER"/>
                <ColumnConstraints percentWidth="50.0" halignment="CENTER"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints percentHeight="50.0" valignment="CENTER"/>
                <RowConstraints percentHeight="50.0" valignment="CENTER"/>
            </rowConstraints>

            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" alignment="CENTER" spacing="5.0">
                <Text fx:id="nameP2" text="Nom Adversaire"/>
                <ProgressBar fx:id="healthBarP2" progress="1.0" prefWidth="150.0"/>
                <Text fx:id="hpTextP2" text="HP / HP"/>
            </VBox>

            <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" alignment="CENTER" spacing="5.0">
                <Text fx:id="nameP1" text="Nom Joueur"/>
                <ProgressBar fx:id="healthBarP1" progress="1.0" prefWidth="150.0"/>
                <Text fx:id="hpTextP1" text="HP / HP"/>
            </VBox>
        </GridPane>

        <VBox GridPane.columnIndex="0"
              GridPane.rowIndex="4"
              GridPane.columnSpan="2"
              maxHeight="Infinity"
              maxWidth="Infinity"
              spacing="10.0">
            <Text>CAPACITES</Text>
            <HBox spacing="10.0">
                <Button fx:id="pokemonMove1Data" styleClass="attackArea"/>
                <Button fx:id="pokemonMove2Data" styleClass="attackArea"/>
                <Button fx:id="pokemonMove3Data" styleClass="attackArea"/>
                <Button fx:id="pokemonMove4Data" styleClass="attackArea"/>
            </HBox>

            <Text>POKEMON</Text>
            <HBox>
                <Text>JE SUIS UNE LISTE DE POKEMON</Text>
            </HBox>
        </VBox>

        <VBox GridPane.columnIndex="2"
              GridPane.rowIndex="0"
              GridPane.rowSpan="5"
              maxHeight="Infinity"
              maxWidth="Infinity">
            <Text>JE SUIS UN CHAT</Text>
        </VBox>

    </GridPane>
</VBox>